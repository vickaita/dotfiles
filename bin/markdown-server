        {pygments_css_light}

        @media (prefers-color-scheme: dark) {{
            {pygments_css_dark}
        }}
    </style>
</head>
<body>
    {breadcrumb}
    <main>
        {content}
    </main>
    <script type="module">
        import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
        const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        mermaid.initialize({{
            startOnLoad: true,
            securityLevel: "strict",
            theme: isDark ? "dark" : "default"
        }});

        const EXPAND_STEP = 10;

        async function fetchRange(snippet, start, end) {{
            const params = new URLSearchParams({{
                path: snippet.dataset.path,
                start: String(start),
                end: String(end),
                hash: snippet.dataset.hash || "",
                lang: snippet.dataset.lang || "",
            }});
            const res = await fetch(`/_snippet?${{params}}`);
            if (!res.ok) throw new Error(`snippet fetch failed: ${{res.status}}`);
            return res.json();
        }}

        // Parse the server-rendered Pygments table and return its lineno/code <pre> elements.
        // We never inject markup as a string; we move the parsed DOM nodes directly.
        function parseFragment(htmlString) {{
            const doc = new DOMParser().parseFromString(htmlString, "text/html");
            const linenosPre = doc.querySelector(".linenos pre");
            const codePre = doc.querySelector(".code pre, td.code pre");
            return {{ linenosPre, codePre }};
        }}

        function moveChildren(sourcePre, targetPre, position) {{
            if (!sourcePre || !targetPre) return;
            const newline = document.createTextNode("\\n");
            const nodes = Array.from(sourcePre.childNodes);
            if (position === "prepend") {{
                targetPre.prepend(newline);
                for (let i = nodes.length - 1; i >= 0; i--) {{
                    targetPre.prepend(nodes[i]);
                }}
            }} else {{
                targetPre.append(newline);
                for (const node of nodes) {{
                    targetPre.append(node);
                }}
            }}
        }}

        function targets(snippet) {{
            return {{
                linenosPre: snippet.querySelector(".linenos pre"),
                codePre: snippet.querySelector(".code pre, td.code pre"),
            }};
        }}

        function updateButtons(snippet) {{
            const start = parseInt(snippet.dataset.start, 10);
            const end = parseInt(snippet.dataset.end, 10);
            const total = parseInt(snippet.dataset.total, 10) || 0;
            const up = snippet.querySelector(".snippet-expand-up");
            const down = snippet.querySelector(".snippet-expand-down");
            if (up && start <= 1) up.remove();
            if (down && total > 0 && end >= total) down.remove();
        }}

        document.addEventListener("click", async (event) => {{
            const button = event.target.closest(".snippet-expand");
            if (!button) return;
            const snippet = button.closest(".snippet");
            if (!snippet) return;
            event.preventDefault();

            const direction = button.dataset.direction;
            const start = parseInt(snippet.dataset.start, 10);
            const end = parseInt(snippet.dataset.end, 10);
            const total = parseInt(snippet.dataset.total, 10) || 0;
            const expandAll = event.shiftKey;
            const dest = targets(snippet);
            if (!dest.linenosPre || !dest.codePre) return;

            try {{
                if (direction === "up") {{
                    if (start <= 1) return;
                    const newStart = expandAll ? 1 : Math.max(1, start - EXPAND_STEP);
                    const data = await fetchRange(snippet, newStart, start - 1);
                    const fragment = parseFragment(data.html);
                    moveChildren(fragment.linenosPre, dest.linenosPre, "prepend");
                    moveChildren(fragment.codePre, dest.codePre, "prepend");
                    snippet.dataset.start = String(data.start);
                }} else {{
                    if (total > 0 && end >= total) return;
                    const fallbackEnd = end + EXPAND_STEP;
                    const newEnd = expandAll && total > 0 ? total : fallbackEnd;
                    const data = await fetchRange(snippet, end + 1, newEnd);
                    const fragment = parseFragment(data.html);
                    moveChildren(fragment.linenosPre, dest.linenosPre, "append");
                    moveChildren(fragment.codePre, dest.codePre, "append");
                    snippet.dataset.end = String(data.end);
                    if (!snippet.dataset.total || snippet.dataset.total === "0") {{
                        snippet.dataset.total = String(data.total);
                    }}
                }}
                updateButtons(snippet);
            }} catch (err) {{
                console.error(err);
            }}
        }});
    </script>
</body>
</html>"""


def main():
    """Main entry point"""
    port = int(sys.argv[1]) if len(sys.argv) > 1 else 8000

    server_address = ('', port)
    httpd = HTTPServer(server_address, MarkdownHandler)

    print(f"Markdown Server running at http://localhost:{port}/")
    print(f"Serving: {os.getcwd()}")
    print("Press Ctrl+C to stop")

    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down server...")
        httpd.shutdown()


if __name__ == '__main__':
    main()
