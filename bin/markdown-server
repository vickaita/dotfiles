#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.8"
# dependencies = [
#   "markdown",
#   "pygments",
# ]
# ///
"""
Markdown Server - Serves markdown files as HTML with code embedding support

Usage:
    uv run markdown-server [port]
    or just: markdown-server [port]

Default port: 8000
"""

import json
import os
import subprocess
import sys
import re
import html
import urllib.parse
from datetime import datetime
from http.server import HTTPServer, SimpleHTTPRequestHandler
from pathlib import Path
import markdown
from markdown.extensions import Extension
from markdown.treeprocessors import Treeprocessor
from pygments import highlight
from pygments.lexers import guess_lexer_for_filename, get_lexer_by_name
from pygments.util import ClassNotFound
from pygments.formatters import HtmlFormatter

SNIPPET_PATTERN = re.compile(
    r'^(?P<lead>[ \t]*(?:(?:[-*+]|\d+\.)[ \t]+)?)'
    r'\[(?P<text>[^\]\n]+?)\]\((?P<href>[^)\n]+?)\)[ \t]*\n+'
    r'^(?P<fence_indent>[ \t]*)```(?P<lang>[\w+\-.]*)[ \t]*\n'
    r'(?P<code>.*?)\n'
    r'^(?P=fence_indent)```[ \t]*$',
    re.MULTILINE | re.DOTALL,
)

FRONTMATTER_PATTERN = re.compile(
    r'\A---[ \t]*\r?\n(?P<body>.*?)(?:\r?\n)---[ \t]*(?:\r?\n|$)',
    re.DOTALL,
)

FENCED_CODE_PATTERN = re.compile(
    r'(^[ \t]*```.*?^[ \t]*```[ \t]*$)',
    re.MULTILINE | re.DOTALL,
)

TAGGED_CODE_PATTERN = re.compile(
    r'^(?P<fence_indent>[ \t]*)```(?P<info>[^\n`]*)[ \t]*\n'
    r'(?P<code>.*?)\n'
    r'^(?P=fence_indent)```[ \t]*$',
    re.MULTILINE | re.DOTALL,
)

BACKSLASH_MATH_PATTERN = re.compile(
    r'\\\[(?P<display>.*?)\\\]|\\\((?P<inline>.*?)\\\)',
    re.DOTALL,
)

OBSIDIAN_BLOCK_ANCHOR_PATTERN = re.compile(
    r'[ \t]+\^(?P<anchor>[A-Za-z0-9_-]+)[ \t]*$'
)


class ObsidianBlockAnchorExtension(Extension):
    """Attach Obsidian block anchors (`^id`) to rendered block elements."""

    def extendMarkdown(self, md):
        md.treeprocessors.register(
            ObsidianBlockAnchorTreeprocessor(md),
            'obsidian_block_anchors',
            15,
        )


class ObsidianBlockAnchorTreeprocessor(Treeprocessor):
    TARGET_TAGS = {
        'p', 'li',
        'h1', 'h2', 'h3', 'h4', 'h5', 'h6',
        'dt', 'dd', 'td', 'th',
    }
    SKIP_TAGS = {'code', 'pre', 'script', 'style'}

    def run(self, root):
        self.apply_anchors(root)
        return root

    def apply_anchors(self, element):
        tag = self.local_tag(element)
        if tag in self.SKIP_TAGS:
            return

        if tag in self.TARGET_TAGS:
            self.apply_anchor_to_element(element)

        for child in list(element):
            self.apply_anchors(child)

    def apply_anchor_to_element(self, element):
        for owner, attr, value in reversed(list(self.text_slots(element))):
            if not value.strip():
                continue

            match = OBSIDIAN_BLOCK_ANCHOR_PATTERN.search(value)
            if not match:
                return

            setattr(owner, attr, value[:match.start()])
            element.set('id', f"^{match.group('anchor')}")
            return

    def text_slots(self, element):
        if element.text:
            yield element, 'text', element.text

        for child in list(element):
            tag = self.local_tag(child)
            if tag not in self.SKIP_TAGS and tag not in self.TARGET_TAGS:
                yield from self.text_slots(child)
            if child.tail:
                yield child, 'tail', child.tail

    @staticmethod
    def local_tag(element):
        return element.tag.rsplit('}', 1)[-1] if isinstance(element.tag, str) else ''


def strip_block_indent(text, indent):
    """Strip a common leading indent from each non-blank line."""
    if not indent:
        return text
    out = []
    for line in text.split('\n'):
        if line.startswith(indent):
            out.append(line[len(indent):])
        elif line.strip() == '':
            out.append('')
        else:
            out.append(line)
    return '\n'.join(out)


def preserve_lexer_blank_lines(lexer):
    """Keep Pygments from stripping blank lines out of numbered source ranges."""
    if hasattr(lexer, 'stripnl'):
        lexer.stripnl = False
    if hasattr(lexer, 'stripall'):
        lexer.stripall = False
    return lexer

SNIPPET_TEXT_PATTERN = re.compile(
    r'^(?P<path>[^:\n]+):(?P<start>\d+)(?:-(?P<end>\d+))?(?:#(?P<hash>[0-9a-fA-F]{4,40}))?$'
)


# Image file extensions to display in browser
IMAGE_EXTENSIONS = {'.png', '.jpg', '.jpeg', '.gif', '.svg', '.webp', '.bmp', '.ico'}
SEARCH_RESULT_LIMIT = 20
SEARCH_CONTENT_LIMIT = 40
MARKDOWN_EXTENSIONS = [
    'fenced_code',
    'tables',
    'codehilite',
    'toc',
    'sane_lists',
    'def_list',
    ObsidianBlockAnchorExtension(),
]
MARKDOWN_EXTENSION_CONFIGS = {
    'codehilite': {
        'css_class': 'highlight',
        'guess_lang': False,
    },
}

