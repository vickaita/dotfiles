            --accent-green: oklch(0.480 0.135 150);
            --accent-orange: oklch(0.520 0.145 62);
            --accent-red: oklch(0.500 0.170 25);
            --accent-purple: oklch(0.500 0.145 300);
            --accent-yellow: oklch(0.550 0.135 95);
            --accent: var(--accent-blue);
            --accent-hover: var(--accent-blue-hover);
            --code-bg: #f3f1ea;
            --code-inline-bg: #ecebe4;
            --blockquote-border: #c8c4b6;
            --shadow: 0 1px 2px rgba(0,0,0,0.04);
            --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            --serif: "Source Serif 4", ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
            --mono: Monaco, ui-monospace, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
        }}

        :root[data-theme="dark"] {{
            --bg: #0f1115;
            --surface: #161922;
            --surface-2: #1f2330;
            --border: #2a2f3d;
            --border-strong: #3a4053;
            --text: #e6e8ee;
            --text-muted: #9aa1b3;
            --accent-blue: oklch(0.760 0.115 257);
            --accent-blue-hover: oklch(0.840 0.095 257);
            --accent-green: oklch(0.760 0.120 150);
            --accent-orange: oklch(0.780 0.130 62);
            --accent-red: oklch(0.780 0.120 25);
            --accent-purple: oklch(0.780 0.110 300);
            --accent-yellow: oklch(0.840 0.120 95);
            --accent: var(--accent-blue);
            --accent-hover: var(--accent-blue-hover);
            --code-bg: #161922;
            --code-inline-bg: #1f2330;
            --blockquote-border: #3a4053;
            --shadow: 0 1px 2px rgba(0,0,0,0.4);
        }}

        @media (prefers-color-scheme: dark) {{
            :root:not([data-theme="light"]) {{
                --bg: #0f1115;
                --surface: #161922;
                --surface-2: #1f2330;
