        }}

        a:hover {{ color: var(--accent-hover); text-decoration: underline; }}

        :focus-visible {{
            outline: 2px solid var(--accent);
            outline-offset: 2px;
            border-radius: 2px;
        }}

        h1, h2, h3, h4, h5, h6 {{
            font-family: var(--sans);
            font-weight: 650;
