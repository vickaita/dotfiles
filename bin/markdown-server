def format_size(size):
    if size < 1024:
        return f"{size} B"
    if size < 1024 * 1024:
        return f"{size / 1024:.1f} KB"
    if size < 1024 * 1024 * 1024:
        return f"{size / (1024 * 1024):.1f} MB"
    return f"{size / (1024 * 1024 * 1024):.1f} GB"


class MarkdownHandler(SimpleHTTPRequestHandler):
    """Custom handler for serving markdown files as HTML"""

    def do_GET(self):
        """Handle GET requests"""
        # Parse the URL
        parsed_path = urllib.parse.urlparse(self.path)
        path = urllib.parse.unquote(parsed_path.path)

        if path == '/_snippet':
            return self.serve_snippet_fragment(parsed_path.query)

        if path == '/_search':
            return self.serve_search_results(parsed_path.query)

        canonical_path = re.sub(r'/+', '/', parsed_path.path)
        if canonical_path != parsed_path.path:
            return self.redirect_to_url_path(parsed_path, canonical_path)

        # Remove leading slash and resolve to filesystem path
        if path.startswith('/'):
            path = path[1:]

        path = self.strip_line_suffix(path)
        fs_path = self.resolve_request_path(path)

        # Handle directories
        if fs_path.is_dir():
            if not parsed_path.path.endswith('/'):
                return self.redirect_to_directory_url(parsed_path)

            # Check for index.html first
            index_html = fs_path / 'index.html'
            if index_html.exists():
                return self.serve_static_file(index_html)

            # Then check for index.md
            index_md = fs_path / 'index.md'
            if index_md.exists():
                return self.serve_markdown(index_md)

            # Otherwise serve directory listing
            return self.serve_directory_listing(fs_path, path)

        # Handle markdown files
        if fs_path.suffix == '.md' and fs_path.exists():
            return self.serve_markdown(fs_path)

        # Handle image files
        if fs_path.suffix.lower() in IMAGE_EXTENSIONS and fs_path.exists():
            # Check if this is a direct browser navigation (wants HTML viewer)
            # vs an image resource request from an img tag (wants raw image)
            accept = self.headers.get('Accept', '')
            wants_html = 'text/html' in accept
            wants_image = 'image' in accept

            # If browser prefers HTML over images, show the viewer page
            if wants_html and (not wants_image or accept.index('text/html') < accept.index('image')):
                return self.serve_image(fs_path, path)
            else:
                # Serve the raw image file for img tags
                return self.serve_static_file(fs_path)

        # Try to serve all other files as text with line numbers
        # Binary files will fall back to normal serving
        if fs_path.exists() and fs_path.is_file():
            return self.serve_source_code(fs_path)

        # Default behavior for files that don't exist
        return super().do_GET()

    def redirect_to_directory_url(self, parsed_path):
        """Redirect directory URLs to a trailing slash for relative links."""
        return self.redirect_to_url_path(parsed_path, f'{parsed_path.path}/')

    def redirect_to_url_path(self, parsed_path, url_path):
        """Redirect while preserving query parameters."""
        location = urllib.parse.urlunparse((
            '',
            '',
            url_path,
            parsed_path.params,
            parsed_path.query,
            '',
        ))
        self.send_response(301)
        self.send_header('Location', location)
        self.send_header('Content-Length', '0')
        self.end_headers()

    @staticmethod
    def strip_line_suffix(path):
        """Remove editor-style :line or :line-range suffixes from URL paths."""
        return re.sub(r':\d+(?:-\d+)?$', '', path)

    def resolve_request_path(self, path):
        """Map a URL path to a file, allowing links to sibling workspace dirs."""
        cwd = Path(os.getcwd()).resolve()
        if not path:
            return cwd

        primary = (cwd / path).resolve()
        if primary.exists():
            return primary

        sibling = (cwd.parent / path).resolve()
        if sibling.exists():
            return sibling

        return primary

    def serve_static_file(self, file_path):
        """Serve a file directly from an already-resolved filesystem path."""
        try:
            with open(file_path, 'rb') as f:
                stat = os.fstat(f.fileno())
                self.send_response(200)
                self.send_header('Content-type', self.guess_type(str(file_path)))
                self.send_header('Content-Length', str(stat.st_size))
                self.send_header('Last-Modified', self.date_time_string(stat.st_mtime))
                self.end_headers()
                self.copyfile(f, self.wfile)
        except OSError:
            self.send_error(404, "File not found")

    def serve_markdown(self, file_path):
        """Convert and serve markdown file as HTML"""
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()

            # Render YAML-style frontmatter as a visible preformatted block.
            content = self.process_frontmatter(content)

            # Process wikilinks [[Topic]] -> Topic.md links
            content = self.process_wikilinks(content)

            # Replace task-list checkboxes with SVG icons
            content = self.process_tasks(content)

            # Replace [path:line-range](href) + ```code``` pairs with placeholders.
            # Real HTML is spliced back in after the markdown pass.
            content, snippet_blocks = self.process_code_snippets(content, file_path.parent)

            # Convert Mermaid fences into browser-rendered diagram blocks
            content = self.process_mermaid_blocks(content)

            # Convert tagged fenced code blocks into collapsible labeled blocks.
            content, code_blocks = self.process_tagged_code_blocks(content)

            # Preserve \(inline\) and \[display\] math delimiters through Markdown.
            content, math_blocks = self.process_backslash_math(content)

            # Convert markdown to HTML
            html_content = markdown.markdown(
                content,
                extensions=MARKDOWN_EXTENSIONS,
                extension_configs=MARKDOWN_EXTENSION_CONFIGS,
            )

            for token, snippet_html in snippet_blocks.items():
                html_content = html_content.replace(f'<p>{token}</p>', snippet_html)
                # Fallback for tight lists where the token isn't wrapped in <p>.
                html_content = html_content.replace(token, snippet_html)

            for token, code_html in code_blocks.items():
                html_content = html_content.replace(f'<p>{token}</p>', code_html)
                html_content = html_content.replace(token, code_html)

            for token, math_html in math_blocks.items():
                html_content = html_content.replace(f'<p>{token}</p>', math_html)
                html_content = html_content.replace(token, math_html)

            # Wrap in HTML template
            full_html = self.wrap_html(
                html_content,
                file_path.name,
                url_path=self.relative_url(file_path),
            )

            # Send response
            self.send_response(200)
            self.send_header('Content-type', 'text/html; charset=utf-8')
            self.send_header('Content-Length', len(full_html.encode('utf-8')))
            self.end_headers()
            self.wfile.write(full_html.encode('utf-8'))

        except Exception as e:
            self.send_error(500, f"Error processing markdown: {str(e)}")

    def serve_image(self, file_path, url_path):
        """Serve image file in an HTML wrapper"""
        try:
            size_str = format_size(file_path.stat().st_size)

            # Create HTML with the image
            # Use the URL path for the image src so it loads correctly
            html_content = f'''<div class="image-viewer">
                <div class="image-header">
                    <span class="filename">{file_path.name}</span>
                    <span class="filesize">{size_str}</span>
                </div>
                <div class="image-container">
                    <img src="/{url_path}" alt="{file_path.name}" />
                </div>
            </div>'''

            # Wrap in HTML template
            full_html = self.wrap_html(html_content, file_path.name, url_path=url_path)

            # Send response
            self.send_response(200)
            self.send_header('Content-type', 'text/html; charset=utf-8')
            self.send_header('Content-Length', len(full_html.encode('utf-8')))
            self.end_headers()
            self.wfile.write(full_html.encode('utf-8'))

        except Exception as e:
            self.send_error(500, f"Error displaying image: {str(e)}")

    def serve_source_code(self, file_path):
        """Serve text file with line numbers and syntax highlighting if recognized"""
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                code = f.read()

            # Try syntax highlighting with pygments
            try:
                lexer = preserve_lexer_blank_lines(guess_lexer_for_filename(file_path, code))
                formatter = HtmlFormatter(
                    linenos='table',
                    cssclass='highlight',
                    full=False
                )
                highlighted = highlight(code, lexer, formatter)
                html_content = f'<div class="source-file"><div class="file-header">{file_path.name}</div>{highlighted}</div>'
            except Exception:
                # Fallback: plain text with line numbers
                lines = code.split('\n')
                line_numbers = '\n'.join(str(i) for i in range(1, len(lines) + 1))
                escaped_code = self.escape_html(code)

                html_content = f'''<div class="source-file">
                    <div class="file-header">{file_path.name}</div>
                    <div class="highlight">
                        <table class="highlighttable"><tr>
                            <td class="linenos"><pre>{line_numbers}</pre></td>
                            <td class="code"><pre><code>{escaped_code}</code></pre></td>
                        </tr></table>
                    </div>
                </div>'''

            # Wrap in HTML template
            full_html = self.wrap_html(
                html_content,
                file_path.name,
                url_path=self.relative_url(file_path),
            )

            # Send response
            self.send_response(200)
            self.send_header('Content-type', 'text/html; charset=utf-8')
            self.send_header('Content-Length', len(full_html.encode('utf-8')))
            self.end_headers()
            self.wfile.write(full_html.encode('utf-8'))

        except UnicodeDecodeError:
            # File is likely binary, serve it normally
            return self.serve_static_file(file_path)
        except Exception as e:
            self.send_error(500, f"Error processing source file: {str(e)}")

    def serve_snippet_fragment(self, query_string):
        """Return Pygments-highlighted HTML for a range of a file.

        Query params: path (abs), start, end, hash (optional), lang (optional).
        Responds with JSON: {html, start, end, total}.
        """
        try:
            params = urllib.parse.parse_qs(query_string)
            abs_path = Path(params['path'][0])
            start = max(1, int(params['start'][0]))
            end = max(start, int(params['end'][0]))
            commit_hash = params.get('hash', [''])[0]
            lang = params.get('lang', [''])[0]

            lines = self.read_source_lines(abs_path, commit_hash)
            total = len(lines)
            end = min(end, total)
            code = '\n'.join(lines[start - 1:end])
            highlighted = self.highlight_snippet(lang, abs_path, code, start)

            payload = json.dumps({
                'html': highlighted,
                'start': start,
                'end': end,
                'total': total,
            }).encode('utf-8')

            self.send_response(200)
            self.send_header('Content-type', 'application/json; charset=utf-8')
            self.send_header('Content-Length', len(payload))
            self.end_headers()
            self.wfile.write(payload)
        except Exception as e:
            self.send_error(500, f'Error loading snippet: {e}')

    def serve_search_results(self, query_string):
        """Return filename and content search results for the served root."""
        try:
            params = urllib.parse.parse_qs(query_string)
            query = params.get('q', [''])[0].strip()
            results = self.search(query)
            payload = json.dumps({'results': results}).encode('utf-8')

            self.send_response(200)
            self.send_header('Content-type', 'application/json; charset=utf-8')
            self.send_header('Content-Length', len(payload))
            self.end_headers()
            self.wfile.write(payload)
        except Exception as e:
            self.send_error(500, f'Error searching: {e}')

    def search(self, query):
        """Search the served root by filename first, then file contents."""
        if not query:
            return []

        root = Path(os.getcwd()).resolve()
        results = []
        seen = set()

        for rel_path in self.search_filename_matches(root, query):
            key = ('filename', rel_path)
            if key in seen:
                continue
            seen.add(key)
            results.append({
                'type': 'filename',
                'path': rel_path,
                'url': self.search_url(rel_path),
                'label': rel_path,
            })
            if len(results) >= SEARCH_RESULT_LIMIT:
                return results

        for match in self.search_content_matches(root, query):
            key = ('content', match['path'], match['line'])
            if key in seen:
                continue
            seen.add(key)
            results.append(match)
            if len(results) >= SEARCH_RESULT_LIMIT:
                break

        return results

    def search_filename_matches(self, root, query):
        query_lower = query.lower()
        matches = []
        for rel_path in self.rg_files(root):
            name_lower = rel_path.lower()
            index = name_lower.find(query_lower)
            if index == -1:
                continue
            basename = Path(rel_path).name.lower()
            basename_index = basename.find(query_lower)
            matches.append((
                0 if basename_index == 0 else 1 if basename_index > -1 else 2,
                index,
                len(rel_path),
                rel_path,
            ))
        return [match[-1] for match in sorted(matches)[:SEARCH_RESULT_LIMIT]]

    def rg_files(self, root):
        try:
            result = subprocess.run(
                ['rg', '--files'],
                cwd=str(root),
                capture_output=True,
                check=False,
                text=True,
            )
        except FileNotFoundError:
            return self.walk_files(root)
        if result.returncode not in (0, 1):
            return []
        return [
            path for path in result.stdout.splitlines()
            if self.is_safe_search_path(path)
        ]

    def walk_files(self, root):
        paths = []
        for current_root, dirnames, filenames in os.walk(root):
            dirnames[:] = [
                dirname for dirname in dirnames
                if not dirname.startswith('.') and dirname != '__pycache__'
            ]
            for filename in filenames:
                if filename.startswith('.'):
                    continue
                abs_path = Path(current_root) / filename
                try:
                    rel_path = str(abs_path.relative_to(root))
                except ValueError:
                    continue
                if self.is_safe_search_path(rel_path):
                    paths.append(rel_path)
        return paths

    def search_content_matches(self, root, query):
        try:
            result = subprocess.run(
                [
                    'rg',
                    '--json',
                    '--fixed-strings',
                    '--smart-case',
                    '--max-count', '3',
                    '--',
                    query,
                    '.',
                ],
                cwd=str(root),
                capture_output=True,
                check=False,
                text=True,
            )
        except FileNotFoundError:
            return []

        if result.returncode not in (0, 1):
            return []

        matches = []
        for line in result.stdout.splitlines():
            if len(matches) >= SEARCH_CONTENT_LIMIT:
                break
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue
            if event.get('type') != 'match':
                continue
            data = event.get('data', {})
            path = data.get('path', {}).get('text', '')
            path = path[2:] if path.startswith('./') else path
            if not self.is_safe_search_path(path):
                continue
            line_number = data.get('line_number')
            preview = data.get('lines', {}).get('text', '').strip()
            if not path or not line_number:
                continue
            matches.append({
                'type': 'content',
                'path': path,
                'url': self.search_url(path, line_number),
                'line': line_number,
                'preview': preview,
                'label': f'{path}:{line_number}',
            })
        return matches

    @staticmethod
    def is_safe_search_path(path):
        if not path or path.startswith('/'):
            return False
        parts = Path(path).parts
        return '..' not in parts

    @staticmethod
    def search_url(rel_path, line=None):
        url = '/' + urllib.parse.quote(rel_path, safe='/')
        if line:
            url += f':{line}'
        return url

    def process_frontmatter(self, content):
        """Render top-of-file frontmatter in a preformatted box."""
        match = FRONTMATTER_PATTERN.match(content)
        if not match:
            return content

        frontmatter = match.group('body').replace('\r\n', '\n')
        rendered = (
            '<div class="frontmatter-block">'
            '<div class="frontmatter-label">'
            '<span>frontmatter</span>'
            '<button class="frontmatter-toggle" type="button" '
            'aria-expanded="true" aria-controls="frontmatter-content" '
            'aria-label="Collapse frontmatter">'
            '<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">'
            '<path d="M4 10l4-4 4 4" fill="none" stroke="currentColor" '
            'stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>'
            '</svg>'
            '</button>'
            '</div>'
            '<pre class="frontmatter" id="frontmatter-content"><code>'
            f'{html.escape(frontmatter)}'
            '</code></pre>'
            '</div>\n\n'
        )
        return rendered + content[match.end():]

    def process_tagged_code_blocks(self, content):
        """Render tagged fenced code blocks with a collapsible language strip."""
        blocks = {}

        def replace(match):
            info = (match.group('info') or '').strip()
            if not info:
                return match.group(0)

            lang = info.split()[0].strip()
            if not lang:
                return match.group(0)

            code = strip_block_indent(match.group('code'), match.group('fence_indent') or '')
            token = f'CODEBLOCKPLACEHOLDER{len(blocks):04d}TOKEN'
            blocks[token] = self.render_code_block(lang, code, len(blocks))
            return token

        return TAGGED_CODE_PATTERN.sub(replace, content), blocks

    def render_code_block(self, lang, code, index):
        """Render a tagged fenced code block with syntax highlighting."""
        lang_label = html.escape(lang)
        content_id = f'codeblock-content-{index}'
        label = f'{lang} code'
        return (
            '<div class="codeblock-block">'
            '<div class="codeblock-label">'
            f'<span>{lang_label}</span>'
            '<button class="codeblock-toggle" type="button" '
            f'aria-expanded="true" aria-controls="{content_id}" '
            f'aria-label="Collapse {html.escape(label, quote=True)}" '
            f'data-toggle-label="{html.escape(label, quote=True)}">'
            '<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">'
            '<path d="M4 10l4-4 4 4" fill="none" stroke="currentColor" '
            'stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>'
            '</svg>'
            '</button>'
            '</div>'
            f'<div id="{content_id}" class="codeblock-content">'
            f'{self.highlight_code_block(lang, code)}'
            '</div>'
            '</div>'
        )

    def highlight_code_block(self, lang, code):
        """Return Pygments-highlighted HTML for a tagged fenced code block."""
        formatter = HtmlFormatter(cssclass='highlight')
        try:
            lexer = preserve_lexer_blank_lines(get_lexer_by_name(lang, stripnl=False))
        except (ClassNotFound, Exception):
            from pygments.lexers.special import TextLexer
            lexer = preserve_lexer_blank_lines(TextLexer())
        return highlight(code, lexer, formatter)

    def process_backslash_math(self, content):
        """Protect LaTeX backslash math delimiters from Markdown escaping."""
        blocks = {}
        segments = FENCED_CODE_PATTERN.split(content)

        def replace(match):
            display = match.group('display')
            if display is not None:
                if not display.strip():
                    return match.group(0)
                rendered = (
                    '<div class="math-display">'
                    f'\\[{html.escape(display)}\\]'
                    '</div>'
                )
            else:
                if not match.group('inline').strip():
                    return match.group(0)
                rendered = (
                    '<span class="math-inline">'
                    f'\\({html.escape(match.group("inline"))}\\)'
                    '</span>'
                )

            token = f'MATHPLACEHOLDER{len(blocks):04d}TOKEN'
            blocks[token] = rendered
            return token

        for index in range(0, len(segments), 2):
            segments[index] = BACKSLASH_MATH_PATTERN.sub(replace, segments[index])

        return ''.join(segments), blocks

    def process_wikilinks(self, content):
        """Process wikilinks: [[Topic]] or [[Topic|Display Text]]"""
        def replace_wikilink(match):
            link_content = match.group(1)

            # Check for pipe syntax: [[Topic|Display Text]]
            if '|' in link_content:
                topic, display = link_content.split('|', 1)
                topic = topic.strip()
                display = display.strip()
            else:
                topic = link_content.strip()
                display = topic

            # Convert to markdown link
            return f'[{display}]({topic}.md)'

        return re.sub(r'\[\[([^\]]+)\]\]', replace_wikilink, content)

    def process_tasks(self, content):
        """Replace `- [ ]`, `- [x]`, `- [-]` checkboxes with SVG icons."""
        state_map = {' ': 'open', 'x': 'done', '-': 'wip'}

        def replace(match):
            prefix = match.group(1)
            state = state_map[match.group('state').lower()]
            return f'{prefix}{TASK_ICONS[state]} '

        return TASK_PATTERN.sub(replace, content)

    def process_code_snippets(self, content, base_path):
        """Replace [path:start-end(#hash)](href) + ```code``` pairs with placeholders.

        Returns (modified_content, {token: html_block}). The caller substitutes
        rendered HTML for each token after running the markdown converter.
        """
        blocks = {}

        def replace(match):
            link_text = match.group('text').strip()
            link_meta = SNIPPET_TEXT_PATTERN.match(link_text)
            if not link_meta:
                return match.group(0)

            href = match.group('href').strip()
            lang = (match.group('lang') or '').strip()
            fence_indent = match.group('fence_indent') or ''
            code = strip_block_indent(match.group('code'), fence_indent)

            rel_path = link_meta.group('path').strip()
            start = int(link_meta.group('start'))
            end = int(link_meta.group('end')) if link_meta.group('end') else start
            commit_hash = link_meta.group('hash') or ''

            try:
                abs_path = (base_path / rel_path).resolve()
            except (OSError, ValueError):
                return match.group(0)

            snippet_html = self.render_snippet_block(
                rel_path=rel_path,
                abs_path=abs_path,
                href=href,
                start=start,
                end=end,
                commit_hash=commit_hash,
                lang=lang,
                code=code,
            )

            token = f'SNIPPETPLACEHOLDER{len(blocks):04d}TOKEN'
            blocks[token] = snippet_html
            lead = match.group('lead') or ''
            return f'{lead}{token}'

        new_content = SNIPPET_PATTERN.sub(replace, content)
        return new_content, blocks

    @staticmethod
    def snippet_chevron_svg(direction):
        path = 'M4 10l4-4 4 4' if direction == 'up' else 'M4 6l4 4 4-4'
        return (
            '<svg class="chev" viewBox="0 0 16 16" width="16" height="16" '
            'aria-hidden="true" focusable="false">'
            f'<path d="{path}" fill="none" stroke="currentColor" stroke-width="2" '
            'stroke-linecap="round" stroke-linejoin="round"/>'
            '</svg>'
        )

    def render_snippet_block(self, rel_path, abs_path, href, start, end,
                             commit_hash, lang, code):
        """Render a single snippet card to HTML."""
        statuses = self.snippet_status(abs_path, start, end, commit_hash, code)
        body_html = self.highlight_snippet(lang, abs_path, code, start)

        # Determine total line count to know if expand has more to reveal.
        try:
            total = self.count_source_lines(abs_path, commit_hash)
        except Exception:
            total = 0

        label = html.escape(f'{rel_path}:{start}' + (f'-{end}' if end != start else '')
                            + (f'#{commit_hash}' if commit_hash else ''))
        # Strip line numbers and commit hash from href for actual link target
        clean_href = href.split(':')[0] if ':' in href else href
        clean_href = clean_href.split('#')[0] if '#' in clean_href else clean_href
        href_attr = html.escape(clean_href, quote=True)
        data_attrs = (
            f'data-path="{html.escape(str(abs_path), quote=True)}" '
            f'data-start="{start}" data-end="{end}" '
            f'data-hash="{html.escape(commit_hash, quote=True)}" '
            f'data-lang="{html.escape(lang, quote=True)}" '
            f'data-total="{total}"'
        )

        badges_html = ''.join(self.render_status_badge(s) for s in statuses)

        expand_up = (
            '<button class="snippet-expand snippet-expand-up" data-direction="up" '
            'type="button" title="Show more above (shift-click for all)">'
            f'{self.snippet_chevron_svg("up")} show more above</button>'
            if start > 1 else ''
        )
        expand_down = (
            '<button class="snippet-expand snippet-expand-down" data-direction="down" '
            'type="button" title="Show more below (shift-click for all)">'
            f'{self.snippet_chevron_svg("down")} show more below</button>'
            if total == 0 or end < total else ''
        )

        return (
            f'<div class="snippet" {data_attrs}>'
            f'<div class="snippet-header">'
            f'<a class="snippet-link" href="{href_attr}">{label}</a>'
            f'{badges_html}'
            f'</div>'
            f'{expand_up}'
            f'<div class="snippet-body">{body_html}</div>'
            f'{expand_down}'
            f'</div>'
        )

    def highlight_snippet(self, lang, abs_path, code, linenostart):
        """Return Pygments-highlighted HTML with a starting line number."""
        formatter = HtmlFormatter(linenos='table', linenostart=linenostart,
                                  cssclass='highlight')
        try:
            if lang:
                lexer = get_lexer_by_name(lang, stripnl=False)
            else:
                lexer = guess_lexer_for_filename(str(abs_path), code)
            lexer = preserve_lexer_blank_lines(lexer)
        except (ClassNotFound, Exception):
            try:
                lexer = preserve_lexer_blank_lines(guess_lexer_for_filename(str(abs_path), code))
            except Exception:
                from pygments.lexers.special import TextLexer
                lexer = preserve_lexer_blank_lines(TextLexer())
        return highlight(code, lexer, formatter)

    def read_source_lines(self, abs_path, commit_hash):
        """Return the file content as a list of lines (no trailing newlines)."""
        if commit_hash:
            repo_root = self.find_git_root(abs_path)
            if not repo_root:
                raise FileNotFoundError(f'no git repo for {abs_path}')
            rel = abs_path.resolve().relative_to(repo_root.resolve())
            result = subprocess.run(
                ['git', '-C', str(repo_root), 'show', f'{commit_hash}:{rel}'],
                capture_output=True, check=True, text=True,
            )
            text = result.stdout
        else:
            text = Path(abs_path).read_text(encoding='utf-8')
        return text.splitlines()

    def count_source_lines(self, abs_path, commit_hash):
        try:
            return len(self.read_source_lines(abs_path, commit_hash))
        except Exception:
            return 0

    @staticmethod
    def find_git_root(path):
        path = Path(path).resolve()
        for ancestor in [path, *path.parents]:
            if (ancestor / '.git').exists():
                return ancestor
        return None

    BADGES = {
        'drifted': ('drifted', 'Snippet differs from source'),
        'missing-commit': ('missing commit', 'Link has no commit hash; comparing against working tree'),
        'invalid-commit': ('invalid commit', 'Commit hash not found in repository'),
    }

    WARN_ICON = (
        '<svg class="warn-icon" viewBox="0 0 16 16" width="12" height="12" aria-hidden="true">'
        '<path fill="currentColor" d="M7.13 1.86a1 1 0 0 1 1.74 0l6.43 11.32A1 1 0 0 1 14.43 15H1.57a1 1 0 0 1-.87-1.82L7.13 1.86zM8 5.5a.75.75 0 0 0-.75.75v3.5a.75.75 0 0 0 1.5 0v-3.5A.75.75 0 0 0 8 5.5zm0 6.25a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>'
        '</svg>'
    )

    def render_status_badge(self, status):
        label, title = self.BADGES.get(status, (status, ''))
        return (
            f'<span class="snippet-badge snippet-badge-{status}" title="{html.escape(title, quote=True)}">'
            f'{self.WARN_ICON}<span>{html.escape(label)}</span></span>'
        )

    def snippet_status(self, abs_path, start, end, commit_hash, code):
        """Return a list of warning statuses for a snippet.

        Possible values: 'missing-commit', 'invalid-commit', 'drifted'.
        """
        statuses = []
        if commit_hash:
            try:
                lines = self.read_source_lines(abs_path, commit_hash)
            except Exception:
                return ['invalid-commit']
        else:
            statuses.append('missing-commit')
            try:
                lines = self.read_source_lines(abs_path, '')
            except Exception:
                return statuses

        actual = lines[start - 1:end]
        pasted = code.split('\n')
        # Tolerate a single trailing empty line in the pasted block.
        if pasted and pasted[-1] == '':
            pasted = pasted[:-1]
        if actual != pasted:
            statuses.append('drifted')
        return statuses

    def process_mermaid_blocks(self, content):
        """Convert fenced Mermaid blocks to HTML consumed by Mermaid JS."""
        pattern = r'^```[ \t]*mermaid[^\n]*\n(.*?)^```[ \t]*$'

        def replace_mermaid(match):
            diagram = match.group(1).strip('\n')
            escaped_diagram = html.escape(diagram, quote=False)
            return f'<pre class="mermaid">{escaped_diagram}</pre>'

        return re.sub(pattern, replace_mermaid, content, flags=re.MULTILINE | re.DOTALL)

    def escape_html(self, text):
        """Escape HTML special characters"""
        return text.replace('&', '&amp;').replace('<', '&lt;').replace('>', '&gt;')

    def serve_directory_listing(self, dir_path, url_path):
        """Serve a simple directory listing"""
        try:
            entries = sorted(dir_path.iterdir(), key=lambda x: (not x.is_dir(), x.name.lower()))

            rows = []
            if url_path:
                parent = str(Path(url_path).parent) if url_path != '.' else ''
                parent_href = f'/{parent}' if parent and parent != '.' else '/'
                rows.append(
                    f'<tr class="dir"><td class="name"><a href="{parent_href}">'
                    f'{FOLDER_ICON}<span>..</span></a></td>'
                    f'<td class="size"></td><td class="modified"></td></tr>'
                )

            for entry in entries:
                name = html.escape(entry.name)
                link = f'/{url_path}/{entry.name}' if url_path else f'/{entry.name}'
                link = html.escape(urllib.parse.quote(link), quote=True)
                try:
                    stat = entry.stat()
                    modified = datetime.fromtimestamp(stat.st_mtime).strftime('%Y-%m-%d %H:%M')
                except OSError:
                    stat = None
                    modified = ''

                if entry.is_dir():
                    rows.append(
                        f'<tr class="dir"><td class="name"><a href="{link}">'
                        f'{FOLDER_ICON}<span>{name}/</span></a></td>'
                        f'<td class="size"></td><td class="modified">{modified}</td></tr>'
                    )
                else:
                    size = format_size(stat.st_size) if stat else ''
                    rows.append(
                        f'<tr class="file"><td class="name"><a href="{link}">'
                        f'{FILE_ICON}<span>{name}</span></a></td>'
                        f'<td class="size">{size}</td><td class="modified">{modified}</td></tr>'
                    )

            display_path = f"/{url_path}" if url_path else "/"
            html_content = (
                f'<h1 class="dir-title">Index of {html.escape(display_path)}</h1>'
                '<table class="dir-listing"><thead><tr>'
                '<th>Name</th><th>Size</th><th>Modified</th>'
                '</tr></thead><tbody>'
                + ''.join(rows) +
                '</tbody></table>'
            )

            title = f"Index of /{url_path}" if url_path else "Index of /"
            full_html = self.wrap_html(html_content, title, url_path=url_path)

            self.send_response(200)
            self.send_header('Content-type', 'text/html; charset=utf-8')
            self.send_header('Content-Length', len(full_html.encode('utf-8')))
            self.end_headers()
            self.wfile.write(full_html.encode('utf-8'))

        except Exception as e:
            self.send_error(500, f"Error listing directory: {str(e)}")

    def relative_url(self, file_path):
        """Compute the URL path (no leading slash) for a filesystem path."""
        resolved = Path(file_path).resolve()
        cwd = Path(os.getcwd()).resolve()
        try:
            return str(resolved.relative_to(cwd))
        except (ValueError, OSError):
            try:
                return str(Path('..') / resolved.relative_to(cwd.parent))
            except (ValueError, OSError):
                return ''

    def render_breadcrumb(self, url_path):
        """Build a breadcrumb of clickable path segments."""
        url_path = (url_path or '').strip('/')
        parts = [p for p in url_path.split('/') if p]
        crumbs = [f'<a href="/" class="crumb-root">~</a>']
        accum = ''
        for i, part in enumerate(parts):
            accum = f'{accum}/{part}' if accum else f'/{part}'
            label = html.escape(part)
            href = html.escape(urllib.parse.quote(accum), quote=True)
            if i == len(parts) - 1:
                crumbs.append(f'<span class="crumb crumb-current">{label}</span>')
            else:
                crumbs.append(f'<a class="crumb" href="{href}">{label}</a>')
        sep = '<span class="crumb-sep">/</span>'
        return f'<nav class="breadcrumb">{sep.join(crumbs)}</nav>'

    @staticmethod
    def prefix_css_selectors(css, prefix):
        """Prefix simple Pygments CSS selectors for theme-scoped overrides."""
        def replace(match):
            selectors = match.group(1).strip()
            prefixed = ', '.join(
                f'{prefix} {selector.strip()}'
                for selector in selectors.split(',')
            )
            return f'{prefixed} {{'

        return re.sub(r'(?m)^([^@\n][^{]+)\{', replace, css)

    def wrap_html(self, content, title="Markdown Server", url_path=''):
        """Wrap content in HTML template with styling"""
        pygments_css_light = HtmlFormatter(style='friendly').get_style_defs('.highlight')
        pygments_css_dark = HtmlFormatter(style='monokai').get_style_defs('.highlight')
        pygments_css_dark_forced = self.prefix_css_selectors(
            pygments_css_dark,
            ':root[data-theme="dark"]',
        )
        pygments_css_dark_system = self.prefix_css_selectors(
            pygments_css_dark,
            ':root:not([data-theme="light"])',
        )
        breadcrumb = self.render_breadcrumb(url_path)
        title_escaped = html.escape(title)

        return f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title_escaped}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&display=swap">
    <script>
        (() => {{
            try {{
                const theme = localStorage.getItem("markdown-server-theme");
                if (theme === "light" || theme === "dark") {{
                    document.documentElement.dataset.theme = theme;
                }}
            }} catch (error) {{
                // Ignore storage access failures and keep the system theme.
            }}
        }})();
    </script>
    <style>
        :root {{
            --bg: #fdfcf9;
            --surface: #f7f5ef;
            --surface-2: #ecebe4;
            --border: #dedbd1;
            --border-strong: #c8c4b6;
            --text: #2a2a2a;
