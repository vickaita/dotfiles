        }}

        .error {{
            background: color-mix(in srgb, var(--accent) 8%, var(--bg));
            border: 1px solid var(--accent);
            color: var(--text);
            padding: 10px 14px;
            border-radius: 6px;
            margin: 1em 0;
        }}

        .mermaid {{
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            margin: 1.6em 0;
            padding: 24px;
            text-align: center;
            box-shadow: var(--shadow);
        }}

        table {{
            border-collapse: collapse;
            width: 100%;
            margin: 1.4em 0;
            font-family: var(--sans);
            font-size: 0.95em;
        }}

        th, td {{
            padding: 8px 12px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }}

        th {{
            border-bottom: 2px solid var(--border-strong);
            font-weight: 600;
            color: var(--text);
        }}

        tbody tr:nth-child(even) td {{ background: var(--surface); }}
        tbody tr:hover td {{ background: var(--surface-2); }}

        .dir-title {{
            font-family: var(--mono);
            font-size: 1.1rem;
            color: var(--text-muted);
            font-weight: 500;
            margin: 0 0 1em;
            padding-bottom: 0.5em;
            border-bottom: 1px solid var(--border);
        }}

        .dir-listing {{ font-family: var(--sans); }}

        .dir-listing .name a {{
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 2px 0;
        }}

        .dir-listing .icon {{
            color: var(--text-muted);
            flex-shrink: 0;
        }}

        .dir-listing tr.dir .icon {{ color: var(--accent); }}

        .dir-listing .size,
        .dir-listing .modified {{
            color: var(--text-muted);
            font-family: var(--mono);
            font-size: 0.85em;
            white-space: nowrap;
            text-align: right;
        }}

        .dir-listing .modified {{ text-align: left; width: 12em; }}
        .dir-listing .size {{ width: 6em; }}

        @media (max-width: 600px) {{
            main {{ padding: 16px 14px 60px; }}
            body {{ font-size: 16px; }}
            h1 {{ font-size: 1.7rem; }}
            h2 {{ font-size: 1.35rem; }}
            .dir-listing .modified {{ display: none; }}
        }}

        @media print {{
            .breadcrumb {{ display: none; }}
            main {{ max-width: none; padding: 0; }}
            body {{ background: white; color: black; font-size: 11pt; }}
            pre, table, .embed-container, .source-file, .image-viewer, .mermaid {{
                box-shadow: none;
                page-break-inside: avoid;
            }}
        }}

        {pygments_css_light}

        @media (prefers-color-scheme: dark) {{
            {pygments_css_dark}
        }}
    </style>
</head>
<body>
    {breadcrumb}
    <main>
        {content}
    </main>
    <script type="module">
        import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
        const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        mermaid.initialize({{
            startOnLoad: true,
            securityLevel: "strict",
            theme: isDark ? "dark" : "default"
        }});
    </script>
</body>
</html>"""


def main():
    """Main entry point"""
    port = int(sys.argv[1]) if len(sys.argv) > 1 else 8000

    server_address = ('', port)
    httpd = HTTPServer(server_address, MarkdownHandler)

    print(f"Markdown Server running at http://localhost:{port}/")
    print(f"Serving: {os.getcwd()}")
    print("Press Ctrl+C to stop")

    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down server...")
        httpd.shutdown()


if __name__ == '__main__':
    main()
