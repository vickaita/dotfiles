            flex-wrap: wrap;
            gap: 4px 6px;
            align-items: center;
        }}

        .breadcrumb .crumb,
        .breadcrumb .crumb-root {{
            color: var(--accent);
            text-decoration: none;
            padding: 2px 4px;
            border-radius: 4px;
        }}

        .breadcrumb .crumb:hover,
        .breadcrumb .crumb-root:hover {{
            background: var(--surface-2);
        }}

        .breadcrumb .crumb-current {{
            color: var(--text);
