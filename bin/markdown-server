                <kbd class="search-key">Esc</kbd>
            </div>
            <div id="search-status" class="search-status">Type to search</div>
            <div id="search-results" class="search-results" role="listbox" aria-label="Search results"></div>
        </section>
    </div>
    <main>
        {content}
    </main>
    <script>
        window.MathJax = {{
            tex: {{
                inlineMath: [["$", "$"], ["\\\\(", "\\\\)"]],
                displayMath: [["$$", "$$"], ["\\\\[", "\\\\]"]],
                processEscapes: true
            }},
            options: {{
                skipHtmlTags: ["script", "noscript", "style", "textarea", "pre", "code"]
            }}
        }};
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>
    <script type="module">
        import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
        const THEME_STORAGE_KEY = "markdown-server-theme";
        const systemThemeQuery = window.matchMedia("(prefers-color-scheme: dark)");

        function getSelectedTheme() {{
            try {{
                const theme = localStorage.getItem(THEME_STORAGE_KEY);
                return theme === "light" || theme === "dark" ? theme : "system";
            }} catch (error) {{
                return "system";
            }}
        }}

        function shouldUseDarkTheme(theme) {{
            return theme === "dark" || (theme === "system" && systemThemeQuery.matches);
        }}

        function applyTheme(theme) {{
            if (theme === "light" || theme === "dark") {{
                document.documentElement.dataset.theme = theme;
            }} else {{
                delete document.documentElement.dataset.theme;
            }}
        }}

        const initialTheme = getSelectedTheme();
        applyTheme(initialTheme);
        const isDark = shouldUseDarkTheme(initialTheme);
        mermaid.initialize({{
            startOnLoad: true,
            securityLevel: "strict",
            theme: isDark ? "dark" : "default"
        }});

        const EXPAND_STEP = 10;
        const SEARCH_DEBOUNCE_MS = 120;
        const configToggle = document.getElementById("config-toggle");
        const configPanel = document.getElementById("config-panel");
        const configClose = document.getElementById("config-close");
        const configScrim = document.getElementById("config-scrim");
        const themeChoices = Array.from(document.querySelectorAll('input[name="theme-choice"]'));
        const searchOverlay = document.getElementById("search-overlay");
        const searchInput = document.getElementById("search-input");
        const searchStatus = document.getElementById("search-status");
        const searchResultsEl = document.getElementById("search-results");
        let searchTimer = null;
        let searchSequence = 0;
        let searchResults = [];
        let activeSearchIndex = -1;

        function isSearchOpen() {{
            return searchOverlay && !searchOverlay.hidden;
        }}

        function isConfigOpen() {{
            return configPanel && configPanel.classList.contains("is-open");
        }}

        function openConfig() {{
            if (!configToggle || !configPanel || !configScrim) return;
            configPanel.classList.add("is-open");
            configPanel.setAttribute("aria-hidden", "false");
            configPanel.removeAttribute("inert");
            configToggle.setAttribute("aria-expanded", "true");
            configToggle.setAttribute("aria-label", "Close configuration");
            configScrim.hidden = false;
            window.setTimeout(() => configClose?.focus(), 0);
        }}

        function closeConfig() {{
            if (!configToggle || !configPanel || !configScrim) return;
            configPanel.classList.remove("is-open");
            configPanel.setAttribute("aria-hidden", "true");
            configPanel.setAttribute("inert", "");
            configToggle.setAttribute("aria-expanded", "false");
            configToggle.setAttribute("aria-label", "Open configuration");
            configScrim.hidden = true;
        }}

        function setThemeChoice(theme) {{
            const selectedTheme = theme === "light" || theme === "dark" ? theme : "system";
            for (const choice of themeChoices) {{
                choice.checked = choice.value === selectedTheme;
            }}
            applyTheme(selectedTheme);
            try {{
                if (selectedTheme === "system") {{
                    localStorage.removeItem(THEME_STORAGE_KEY);
                }} else {{
                    localStorage.setItem(THEME_STORAGE_KEY, selectedTheme);
                }}
            }} catch (error) {{
                // Keep the in-page theme even when browser storage is unavailable.
            }}
        }}

        setThemeChoice(initialTheme);

        if (configToggle) {{
            configToggle.addEventListener("click", () => {{
                if (isConfigOpen()) {{
                    closeConfig();
                }} else {{
                    openConfig();
                }}
            }});
        }}

        if (configClose) {{
            configClose.addEventListener("click", closeConfig);
        }}

        if (configScrim) {{
            configScrim.addEventListener("click", closeConfig);
        }}

        for (const choice of themeChoices) {{
            choice.addEventListener("change", () => {{
                if (choice.checked) setThemeChoice(choice.value);
            }});
        }}

        systemThemeQuery.addEventListener("change", () => {{
            if (getSelectedTheme() === "system") applyTheme("system");
        }});

        function openSearch() {{
            if (!searchOverlay || !searchInput) return;
            searchOverlay.hidden = false;
            window.setTimeout(() => {{
                searchInput.focus();
                searchInput.select();
            }}, 0);
        }}

        function closeSearch() {{
            if (!searchOverlay) return;
            searchOverlay.hidden = true;
        }}

        function setSearchStatus(text) {{
            if (searchStatus) searchStatus.textContent = text;
        }}

        function setActiveSearchIndex(index) {{
            activeSearchIndex = index;
            const items = searchResultsEl ? searchResultsEl.querySelectorAll(".search-result") : [];
            items.forEach((item, itemIndex) => {{
                const isActive = itemIndex === activeSearchIndex;
                item.classList.toggle("is-active", isActive);
                item.setAttribute("aria-selected", isActive ? "true" : "false");
                if (isActive) item.scrollIntoView({{ block: "nearest" }});
            }});
        }}

        function openSearchResult(index) {{
            const result = searchResults[index];
            if (!result) return;
            window.location.href = result.url;
        }}

        function renderSearchResults(results) {{
            if (!searchResultsEl) return;
            searchResults = results;
            searchResultsEl.replaceChildren();
            for (const [index, result] of results.entries()) {{
                const button = document.createElement("button");
                button.type = "button";
                button.className = "search-result";
                button.setAttribute("role", "option");
                button.setAttribute("aria-selected", "false");
                button.dataset.index = String(index);

                const title = document.createElement("span");
                title.className = "search-result-title";
                title.textContent = result.label || result.path;

                const kind = document.createElement("span");
                kind.className = "search-result-kind";
                kind.textContent = result.type === "content" ? "content" : "file";

                button.append(title, kind);
                if (result.preview) {{
                    const preview = document.createElement("span");
                    preview.className = "search-result-preview";
                    preview.textContent = result.preview;
                    button.append(preview);
                }}
                searchResultsEl.append(button);
            }}
            setActiveSearchIndex(results.length ? 0 : -1);
        }}

        async function runSearch(query, sequence) {{
            if (!query) {{
                renderSearchResults([]);
                setSearchStatus("Type to search");
                return;
            }}
            setSearchStatus("Searching...");
            const params = new URLSearchParams({{ q: query }});
            try {{
                const response = await fetch(`/_search?${{params}}`);
                if (!response.ok) throw new Error(`search failed: ${{response.status}}`);
                const data = await response.json();
                if (sequence !== searchSequence) return;
                renderSearchResults(data.results || []);
                setSearchStatus(searchResults.length ? "" : "No results");
            }} catch (error) {{
                if (sequence !== searchSequence) return;
                console.error(error);
                renderSearchResults([]);
                setSearchStatus("Search failed");
            }}
        }}

        function scheduleSearch() {{
            if (!searchInput) return;
            window.clearTimeout(searchTimer);
            const query = searchInput.value.trim();
            const sequence = ++searchSequence;
            searchTimer = window.setTimeout(() => runSearch(query, sequence), SEARCH_DEBOUNCE_MS);
        }}

        document.addEventListener("keydown", (event) => {{
            const key = event.key.toLowerCase();
            if ((event.metaKey || event.ctrlKey) && key === "k") {{
                event.preventDefault();
                openSearch();
                scheduleSearch();
                return;
            }}
            if (!isSearchOpen()) return;
            if (event.key === "Escape") {{
                event.preventDefault();
                closeSearch();
            }} else if (event.key === "ArrowDown" || (event.ctrlKey && key === "n")) {{
                event.preventDefault();
                if (searchResults.length) {{
                    setActiveSearchIndex((activeSearchIndex + 1) % searchResults.length);
                }}
            }} else if (event.key === "ArrowUp" || (event.ctrlKey && key === "p")) {{
                event.preventDefault();
                if (searchResults.length) {{
                    setActiveSearchIndex((activeSearchIndex - 1 + searchResults.length) % searchResults.length);
                }}
            }} else if (event.key === "Enter") {{
                event.preventDefault();
                openSearchResult(activeSearchIndex);
            }}
        }});

        document.addEventListener("keydown", (event) => {{
            if (event.key === "Escape" && isConfigOpen()) {{
                event.preventDefault();
                closeConfig();
                configToggle?.focus();
            }}
        }});

        if (searchInput) {{
            searchInput.addEventListener("input", scheduleSearch);
        }}

        if (searchResultsEl) {{
            searchResultsEl.addEventListener("click", (event) => {{
                const button = event.target.closest(".search-result");
                if (!button) return;
                openSearchResult(parseInt(button.dataset.index, 10));
            }});
            searchResultsEl.addEventListener("mousemove", (event) => {{
                const button = event.target.closest(".search-result");
                if (!button) return;
                setActiveSearchIndex(parseInt(button.dataset.index, 10));
            }});
        }}

        if (searchOverlay) {{
            searchOverlay.addEventListener("click", (event) => {{
                if (event.target === searchOverlay) closeSearch();
            }});
        }}

        async function fetchRange(snippet, start, end) {{
            const params = new URLSearchParams({{
                path: snippet.dataset.path,
                start: String(start),
                end: String(end),
                hash: snippet.dataset.hash || "",
                lang: snippet.dataset.lang || "",
            }});
            const res = await fetch(`/_snippet?${{params}}`);
            if (!res.ok) throw new Error(`snippet fetch failed: ${{res.status}}`);
            return res.json();
        }}

        // Parse the server-rendered Pygments table and return its lineno/code <pre> elements.
        // We never inject markup as a string; we move the parsed DOM nodes directly.
        function parseFragment(htmlString) {{
            const doc = new DOMParser().parseFromString(htmlString, "text/html");
            const linenosPre = doc.querySelector(".linenos pre");
            const codePre = doc.querySelector(".code pre, td.code pre");
            return {{ linenosPre, codePre }};
        }}

        function moveChildren(sourcePre, targetPre, position, addSeparator = true) {{
            if (!sourcePre || !targetPre) return;
            const nodes = Array.from(sourcePre.childNodes);
            const needsSeparator = addSeparator && nodes.length > 0 && targetPre.childNodes.length > 0;
            if (position === "prepend") {{
                if (needsSeparator) targetPre.prepend(document.createTextNode("\\n"));
                for (let i = nodes.length - 1; i >= 0; i--) {{
                    targetPre.prepend(nodes[i]);
                }}
            }} else {{
                if (needsSeparator) targetPre.append(document.createTextNode("\\n"));
                for (const node of nodes) {{
                    targetPre.append(node);
                }}
            }}
        }}

        function targets(snippet) {{
            return {{
                linenosPre: snippet.querySelector(".linenos pre"),
                codePre: snippet.querySelector(".code pre, td.code pre"),
            }};
        }}

        function updateButtons(snippet) {{
            const start = parseInt(snippet.dataset.start, 10);
            const end = parseInt(snippet.dataset.end, 10);
            const total = parseInt(snippet.dataset.total, 10) || 0;
            const up = snippet.querySelector(".snippet-expand-up");
            const down = snippet.querySelector(".snippet-expand-down");
            if (up && start <= 1) up.remove();
            if (down && total > 0 && end >= total) down.remove();
        }}

        document.addEventListener("click", (event) => {{
            const button = event.target.closest(".frontmatter-toggle, .codeblock-toggle");
            if (!button) return;
            const block = button.closest(".frontmatter-block, .codeblock-block");
            const content = block ? block.querySelector(".frontmatter, .codeblock-content") : null;
            if (!content) return;

            const expanded = button.getAttribute("aria-expanded") !== "false";
            const label = button.dataset.toggleLabel || "frontmatter";
            button.setAttribute("aria-expanded", expanded ? "false" : "true");
            button.setAttribute(
                "aria-label",
                `${{expanded ? "Expand" : "Collapse"}} ${{label}}`,
            );
            content.hidden = expanded;
        }});

        document.addEventListener("click", async (event) => {{
            const button = event.target.closest(".snippet-expand");
            if (!button) return;
            const snippet = button.closest(".snippet");
            if (!snippet) return;
            event.preventDefault();

            const direction = button.dataset.direction;
            const start = parseInt(snippet.dataset.start, 10);
            const end = parseInt(snippet.dataset.end, 10);
            const total = parseInt(snippet.dataset.total, 10) || 0;
            const expandAll = event.shiftKey;
            const dest = targets(snippet);
            if (!dest.linenosPre || !dest.codePre) return;

            try {{
                if (direction === "up") {{
                    if (start <= 1) return;
                    const newStart = expandAll ? 1 : Math.max(1, start - EXPAND_STEP);
                    const data = await fetchRange(snippet, newStart, start - 1);
                    const fragment = parseFragment(data.html);
                    moveChildren(fragment.linenosPre, dest.linenosPre, "prepend");
                    moveChildren(fragment.codePre, dest.codePre, "prepend", false);
                    snippet.dataset.start = String(data.start);
                }} else {{
                    if (total > 0 && end >= total) return;
                    const fallbackEnd = end + EXPAND_STEP;
                    const newEnd = expandAll && total > 0 ? total : fallbackEnd;
                    const data = await fetchRange(snippet, end + 1, newEnd);
                    const fragment = parseFragment(data.html);
                    moveChildren(fragment.linenosPre, dest.linenosPre, "append");
                    moveChildren(fragment.codePre, dest.codePre, "append", false);
                    snippet.dataset.end = String(data.end);
                    if (!snippet.dataset.total || snippet.dataset.total === "0") {{
                        snippet.dataset.total = String(data.total);
                    }}
                }}
                updateButtons(snippet);
            }} catch (err) {{
                console.error(err);
            }}
        }});
    </script>
</body>
</html>"""


def main():
    """Main entry point"""
    port = int(sys.argv[1]) if len(sys.argv) > 1 else 8000

    server_address = ('', port)
    httpd = HTTPServer(server_address, MarkdownHandler)

    print(f"Markdown Server running at http://localhost:{port}/")
    print(f"Serving: {os.getcwd()}")
    print("Press Ctrl+C to stop")

    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down server...")
        httpd.shutdown()


if __name__ == '__main__':
    main()
